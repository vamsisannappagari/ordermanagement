{
	"_version": "1.84.0",
	"sap.app": {
		"id": "dashboard",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"supportedLocales": [
				"",
				"en",
				"en-US"
			]
		},
		"applicationVersion": {
			"version": "0.0.1"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"resources": "resources.json",
		"sourceTemplate": {
			"id": "@sap/generator-fiori:alp",
			"version": "1.24.0",
			"toolsId": "8104118c-8309-48fd-8434-3d0a304f8798"
		},
		"dataSources": {
			"mainService": {
				"uri": "/odata/v4/procurement/",
				"type": "OData",
				"settings": {
					"annotations": [],
					"odataVersion": "4.01"
				}
			}
		},
		"crossNavigation": {
			"inbounds": {
				"requester-display": {
					"semanticObject": "requester",
					"action": "display",
					"signature": {
						"parameters": {},
						"additionalParameters": "allowed"
					}
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": true,
		"dependencies": {
			"minUI5Version": "1.148.0",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.fe.templates": {}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "dashboard.i18n.i18n",
					"supportedLocales": [
						"",
						"en",
						"en-US"
					]
				}
			},
			"": {
				"dataSource": "mainService",
				"preload": true,
				"settings": {
					"operationMode": "Server",
					"autoExpandSelect": true,
					"earlyRequests": true
				}
			},
			"@i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/i18n.properties",
				"settings": {
					"supportedLocales": [
						"",
						"en",
						"en-US"
					]
				}
			}
		},
		"resources": {
			"css": []
		},
		"routing": {
			"config": {},
			"routes": [
				{
					"pattern": ":?query:",
					"name": "VendorPerformanceList",
					"target": "VendorPerformanceList"
				},
				{
					"pattern": "VendorPerformance({key}):?query:",
					"name": "VendorPerformanceObjectPage",
					"target": "VendorPerformanceObjectPage"
				}
			],
			"targets": {
				"VendorPerformanceList": {
					"type": "Component",
					"id": "VendorPerformanceList",
					"name": "sap.fe.templates.AnalyticalListPage",
					"options": {
						"settings": {
							"contextPath": "/VendorPerformance",
							"variantManagement": "Page",
							"initialLoad": true,
							"navigation": {
								"VendorPerformance": {
									"detail": {
										"route": "VendorPerformanceObjectPage"
									}
								}
							},
							"controlConfiguration": {
								"@com.sap.vocabularies.UI.v1.LineItem": {
									"tableSettings": {
										"type": "ResponsiveTable",
										"selectionMode": "None",
										"rowSettings": {
											"rowNavigated": true
										}
									},
									"autoBindOnInit": true
								},
								"@com.sap.vocabularies.UI.v1.Chart": {
									"chartSettings": {
										"chartType": "bar"
									},
									"visible": true,
									"autoBindOnInit": true
								}
							}
						}
					}
				},
				"VendorPerformanceObjectPage": {
					"type": "Component",
					"id": "VendorPerformanceObjectPage",
					"name": "sap.fe.templates.ObjectPage",
					"options": {
						"settings": {
							"contextPath": "/VendorPerformance",
							"navigation": {},
							"editableHeaderContent": false,
							"controlConfiguration": {
								"@com.sap.vocabularies.UI.v1.FieldGroup#overview": {
									"fields": {}
								},
								"@com.sap.vocabularies.UI.v1.FieldGroup#performance": {
									"fields": {}
								}
							}
						}
					}
				}
			}
		},
		"flexBundle": false
	},
	"sap.fiori": {
		"registrationIds": [],
		"archeType": "analytical"
	},
	"sap.fe": {
		"app": {
			"enableLazyLoading": false
		}
	},
	"sap.cloud": {
		"public": true,
		"service": "ordermanagement.service"
	}
}