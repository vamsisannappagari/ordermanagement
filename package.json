{
  "name": "ordermanagement",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@cap-js/sqlite": "^2.4.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9",
    "better-sqlite3": "^12.10.0",
    "cds-plugin-ui5": "^0.13.0",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-requester-portal": "cds watch --open app/requesterportal/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-approvaldashboard": "cds watch --open app/approvaldashboard/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-requester": "cds watch --open app/requester/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-approval": "cds watch --open app/approval/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-dashboard": "cds watch --open app/dashboard/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy ordermanagement --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-receipts": "cds watch --open receipts/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "server": {
      "index": true
    },
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "alice": {
            "password": "alice",
            "roles": [
              "Requester"
            ]
          },
          "bob": {
            "password": "bob",
            "roles": [
              "Approver"
            ]
          },
          "carol": {
            "password": "carol",
            "roles": [
              "Buyer"
            ]
          },
          "admin": {
            "password": "admin",
            "roles": [
              "Administrator"
            ]
          }
        }
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        }
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/requesterportal",
    "app/approvaldashboard",
    "app/requester",
    "app/approval",
    "app/dashboard",
    "app/receipts"
  ]
}
